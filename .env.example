# GRCRM lead webhook — investor intake + callback leads POST here as
# { name, email, phone, message }. Paste your GRCRM lead-inbound URL (token in URL).
GRCRM_LEAD_WEBHOOK_URL=
# GRCRM_WEBHOOK_URL is also accepted as a fallback.
GRCRM_WEBHOOK_URL=

# Email forwarding (OPTIONAL) — set ONE provider; the app auto-detects it.
WEB3FORMS_ACCESS_KEY=
FORMSUBMIT_EMAIL=
RESEND_API_KEY=
NOTIFY_EMAIL=
NOTIFY_FROM=

# "Talk to a representative" scheduling link (OPTIONAL; public URL).
NEXT_PUBLIC_BOOKING_URL=
